# Google Sheets (추천) — Apps Script Web App URL
# google-apps-script/Code.gs 배포 후 URL 붙여넣기
NEXT_PUBLIC_GOOGLE_SHEETS_URL=

# Google Forms (대안) — 둘 중 하나만 설정해도 됨
# 폼 미리 채우기 링크에서 entry.xxxxx ID 확인
NEXT_PUBLIC_GOOGLE_FORM_ACTION=
NEXT_PUBLIC_GOOGLE_FORM_ENTRY_ACCEPT=
NEXT_PUBLIC_GOOGLE_FORM_ENTRY_DAY=
NEXT_PUBLIC_GOOGLE_FORM_ENTRY_FOOD=

# 로컬 개발 (npm run dev) — basePath 없음
# NEXT_PUBLIC_BASE_PATH=

# GitHub Pages 빌드 시 자동 설정 (workflow에서 주입)
# GITHUB_PAGES=true
# NEXT_PUBLIC_BASE_PATH=/new-test
